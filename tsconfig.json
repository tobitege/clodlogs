{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "types": ["bun-types", "vite/client"]
  },
  "include": [
    "clodlogs-sessions.ts",
    "electrobun.config.ts",
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
