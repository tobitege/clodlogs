{
  "name": "clodlogs",
  "version": "1.0.0",
  "private": true,
  "description": "Claude session CLI and Electrobun browser.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "clodlogs": "./clodlogs.cjs",
    "clodlogs-sessions": "./clodlogs-sessions.cjs"
  },
  "scripts": {
    "build:web": "vite build",
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build"
  },
  "files": [
    "README.md",
    "clodlogs.cjs",
    "clodlogs-sessions.cjs",
    "clodlogs-sessions.ts",
    "electrobun.config.ts",
    "vite.config.ts",
    "tsconfig.json",
    "src"
  ],
  "engines": {
    "node": ">=22.11.0",
    "bun": ">=1.3.12"
  },
  "dependencies": {
    "electrobun": "1.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
